<PageFunction x:Class="Or.Pages.Beneficiaires"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      x:TypeArguments="sys:Int64"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Or.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800" KeepAlive="True"
      Title="Beneficiaires">

    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Margin="10" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
            <TextBlock Text="BENEFICIAIRES" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Margin="10" Orientation="Vertical" Grid.Row="1" Grid.Column="0">
            <TextBlock x:Name="Numero"  Margin="0,0,0,8" Background="#FFD2D0D0" Height="20" FontSize="14"/>
            <TextBlock x:Name="Nom"     Margin="0,0,0,8" Background="#FFD2D0D0" Height="20" FontSize="14"/>
            <TextBlock x:Name="Prenom"  Margin="0,0,0,8" Background="#FFD2D0D0" Height="20" FontSize="14"/>
        </StackPanel>

        <ListView x:Name="listView" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Top" SizeChanged="ListView_SizeChanged">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Nom" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NomClient}" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Prénom" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PrenomClient}" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="N° compte" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IdCompte}" TextAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Actions" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Supprimer"
                                        Click="Supprimer_Click"
                                        CommandParameter="{Binding IdCompte}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Content="Retour"                    Margin="0,10,0,10" Width="200" Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Click="Retour_Click"/>
        <Button Content="Ajouter un bénéficiaire"   Margin="0,10,0,10" Width="200" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Click="AjouterBeneficiaire_Click"/>
        
    </Grid>
</PageFunction>
