<PageFunction x:Class="Or.Pages.AjouterBeneficiaire"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      x:TypeArguments="sys:Int64"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AjouterBeneficiaire">

    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock  Text="Ajouter un bénéficiaire" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"/>
        <Label      Content="N° de compte du nouveau bénéficiaire" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,30,0,0" FontWeight="SemiBold" Grid.Row="1" Grid.Column="1"/>
        <TextBox    x:Name="NumeroCpt" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,60,0,0" Width="250" Height="30" Grid.Row="1" Grid.Column="1"/>
        <Button     Content="Ajouter un bénéficiaire" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,90,0,0" Width="250" Height="30" Grid.Row="1" Grid.Column="1" Click="Valider_Click"/>
        <Button     Content="Retour" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,120,0,0" Width="250" Height="30" Grid.Row="1" Grid.Column="1" Click="Retour_Click"/>

    </Grid>
</PageFunction>
